# ═══════════════════════════════════════════════════════════════
#  .env — Environment variables for WordPress + MySQL deployment
#
#  HOW TO USE:
#    1. cp .env.example .env
#    2. Fill in every value below
#    3. NEVER commit .env to Git — it's in .gitignore
#    4. On the server: chmod 600 .env  (owner-only read)
# ═══════════════════════════════════════════════════════════════

# ── MySQL ───────────────────────────────────────────────────────
# Root password — used by the MySQL container internally
MYSQL_ROOT_PASSWORD=Q2hhbmRpZ2FyaEAxNw==

# WordPress database name, user, and password
MYSQL_DATABASE=wordpress_db
MYSQL_USER=wp_user
MYSQL_PASSWORD=YXJjaGl0
#(Generate the MYSQL_PASSWORD using base64 to encode the password. Ex: echo -n "archit" | base64)
# or store the password in docker secrets, or Vault.

# ── WordPress ───────────────────────────────────────────────────
# Table prefix — change from default wp_ for basic security
WP_TABLE_PREFIX=wp_

# Enable debug mode only in development (0 = off, 1 = on)
WP_DEBUG=0
